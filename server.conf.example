# Muduo HTTP Server Config (EXAMPLE - copy to server.conf)
[server]
port = 8080
threads = 4
max_body_size = 1048576

[https]
port = 8443
cert_file = certs/server.crt
key_file = certs/server.key

[ai]
api_key = sk-your-key-here
api_base = https://api.openai.com/v1
model = gpt-3.5-turbo
rate_limit_rps = 10
cache_enabled = true

[session]
timeout = 3600

[log]
level = info
file = server.log

[sms]
# 阿里云短信/号码认证配置
access_key_id = your-access-key-id
access_key_secret = your-access-key-secret
sign_name = your-sms-sign-name
template_code = SMS_xxxxxx
scheme_code = FC_xxxxxx
template_code = SMS_xxxxxx
